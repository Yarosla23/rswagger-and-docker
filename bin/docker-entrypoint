#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# If running the Rails server, clean up the stale pid, wait for Postgres, and prepare the database.
if [ "$1" = "./bin/rails" ] && [ "$2" = "server" ]; then
  rm -f /opt/app/tmp/pids/server.pid

  if [ -n "${DATABASE_HOST:-}" ] && [ -n "${DATABASE_USERNAME:-}" ] && [ -n "${DATABASE_NAME:-}" ]; then
    until pg_isready -h "$DATABASE_HOST" -U "$DATABASE_USERNAME" -d "$DATABASE_NAME" >/dev/null 2>&1; do
      sleep 1
    done
  fi

  ./bin/rails db:prepare
fi

exec "${@}"
